#!name=GBF 中文插件
#!desc=Granblue Fantasy 汉化 + 分流优化（BLHXFY）
#!author=cad/OpenAI Codex
#!system=iOS

[Rule]
# 游戏直连（减少战斗卡顿）
DOMAIN-SUFFIX,granbluefantasy.jp,GBF
DOMAIN-SUFFIX,mbga.jp,GBF
DOMAIN-SUFFIX,cygames.jp,GBF

# 汉化资源拉取
DOMAIN-SUFFIX,cdn.jsdelivr.net,Proxy
DOMAIN-SUFFIX,github.com,Proxy

[Rewrite]
# 覆盖游戏配置到 BLHXFY 汉化配置
^https?://(game-a3\.granbluefantasy\.jp|gbf\.game-a3\.mbga\.jp|game\.granbluefantasy\.jp)/assets(_en)?/\d+/js(?:/[^?#]*)?/config\.js(?:\?.*)?$ header https://cdn.jsdelivr.net/gh/biuuu/BLHXFY@gh-pages/blhxfy/game-config.js

[MITM]
hostname = game-a3.granbluefantasy.jp, gbf.game-a3.mbga.jp, game.granbluefantasy.jp
