#!name=GBF 中文插件
#!desc=Granblue Fantasy 汉化 + 分流优化（BLHXFY）
#!author=cad/OpenAI Codex
#!system=iOS

[Rule]
# 游戏直连（减少战斗卡顿）
DOMAIN-SUFFIX,granbluefantasy.jp,GBF
DOMAIN-SUFFIX,mbga.jp,GBF
DOMAIN-SUFFIX,cygames.jp,GBF

# 汉化资源拉取
DOMAIN-SUFFIX,cdn.jsdelivr.net,Proxy
DOMAIN-SUFFIX,github.com,Proxy
DOMAIN-SUFFIX,githubusercontent.com,Proxy

[Rewrite]
# 兼容 game-a3 / game / 其他 a* 入口；兼容 assets 与 assets_en、可选版本目录
^https?://([A-Za-z0-9.-]*granbluefantasy\.jp|[A-Za-z0-9.-]*mbga\.jp)/assets(_en)?(?:/\d+)?/js[^?#]*/config\.js(?:\?.*)?$ url 302 https://cdn.jsdelivr.net/gh/biuuu/BLHXFY@gh-pages/blhxfy/game-config.js

[MITM]
hostname = *.granbluefantasy.jp, *.mbga.jp
