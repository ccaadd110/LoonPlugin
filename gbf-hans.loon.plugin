#!name=GBF 汉化（BLHXFY）
#!desc=将 GBF 的 config.js 302 到 BLHXFY 汉化配置；若仍不生效，请确认 Loon 未绕过 granbluefantasy/mbga 域名。
#!author=OpenAI Codex
#!homepage=https://github.com/biuuu/BLHXFY
#!system=iOS,iPadOS
#!tag=game,translation,granblue-fantasy

[Rewrite]
# 兼容 game-a3 / game / 其他 a* 入口；兼容 assets 与 assets_en、可选版本目录
^https?://([A-Za-z0-9.-]*granbluefantasy\.jp|[A-Za-z0-9.-]*mbga\.jp)/assets(_en)?(?:/\d+)?/js[^?#]*/config\.js(?:\?.*)?$ url 302 https://cdn.jsdelivr.net/gh/biuuu/BLHXFY@gh-pages/blhxfy/game-config.js

[MITM]
hostname = *.granbluefantasy.jp, *.mbga.jp
