[rewrite]
^https?://(game-a3\.granbluefantasy\.jp|gbf\.game-a3\.mbga\.jp)/assets(_en)?/\d+/js[^/]*/config\.js$ header https://cdn.jsdelivr.net/gh/biuuu/BLHXFY@gh-pages/blhxfy/game-config.js

[mitm]
hostname = game-a3.granbluefantasy.jp, gbf.game-a3.mbga.jp
